# Public site URL used for metadata / canonical links.
# NEXT_PUBLIC_SITE_URL=https://nolza.fun

# Google AdSense configuration.
# Leave NEXT_PUBLIC_ADSENSE_CLIENT unset (or keep the "ca-pub-XXX..." placeholder)
# to disable ads entirely; components render null and the AdSense script is not loaded.
# Set all four to enable ads in production.
# NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
# NEXT_PUBLIC_ADSENSE_SLOT_TOP=XXXXXXXXXX
# NEXT_PUBLIC_ADSENSE_SLOT_BOTTOM=XXXXXXXXXX
# NEXT_PUBLIC_ADSENSE_SLOT_MOBILE=XXXXXXXXXX
# NEXT_PUBLIC_ADSENSE_SLOT_SIDE=XXXXXXXXXX

# Google Analytics 4.
# Replace the placeholder with the real GA4 Measurement ID to enable analytics.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Search Console verification.
# Only set this when Google provides a real verification token.
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=xxxxxxxxxxxxxxxx
